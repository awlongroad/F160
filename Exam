.qs-box.box2 .qs-box-cnt{background:rgba(217,119,6,0.12);color:var(--amber)}
.qs-box.box3 .qs-box-cnt{background:rgba(22,163,74,0.12);color:var(--green)}
.qs-box-body{padding:10px;max-height:260px;overflow-y:auto}
.qs-box-item{font-size:12px;line-height:1.5;color:var(--text2);padding:7px 8px;border-radius:6px;margin-bottom:4px;background:var(--surface2)}

/* EXAM SUPPORT PAGE */
.support-content{flex:1;overflow-y:auto;display:flex;flex-direction:column}
/* Support nav */
.sup-nav{background:var(--surface);border-bottom:1px solid var(--border);padding:10px 24px;flex-shrink:0;overflow-x:auto}
.sup-nav-bar{display:flex;align-items:center;gap:14px;min-width:max-content}
.sup-nav-group{display:flex;align-items:center;gap:4px}
.sup-nav-group-label{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.08em;color:var(--text3);white-space:nowrap;margin-right:4px}
.sup-nav-sep{width:1px;height:20px;background:var(--border)}
.sup-nav-pill{padding:6px 14px;border:1.5px solid var(--border);border-radius:20px;font-size:13px;font-weight:500;color:var(--text3);cursor:pointer;background:var(--surface);transition:var(--t);font-family:var(--font);white-space:nowrap}
.sup-nav-pill:hover{border-color:var(--primary);color:var(--primary);background:var(--primary-bg)}
.sup-nav-pill.active{background:var(--primary);border-color:var(--primary);color:#fff;font-weight:600}
.sup-nav-pill.g2:hover{border-color:var(--green);color:var(--green);background:var(--green-bg)}
.sup-nav-pill.g2.active{background:var(--green);border-color:var(--green);color:#fff}
.sup-nav-pill.g3:hover{border-color:var(--po3);color:var(--po3);background:var(--red-bg)}
.sup-nav-pill.g3.active{background:var(--po3);border-color:var(--po3);color:#fff}
.sup-body{max-width:960px;width:100%;margin:0 auto;padding:32px 32px 48px}
.sup-section{}
.sup-h{font-size:22px;font-weight:700;letter-spacing:-0.02em;margin-bottom:4px;color:var(--text)}
.sup-sub{font-size:15px;color:var(--text3);margin-bottom:20px;line-height:1.5}
.po-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.po-card{border-radius:var(--radius);padding:22px;border:2px solid}
.po-card.p1{border-color:var(--po1);background:var(--po1-bg)}
.po-card.p2{border-color:var(--po2);background:var(--po2-bg)}
.po-card.p3{border-color:var(--po3);background:var(--po3-bg)}
.po-card-badge{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:8px;padding:3px 8px;border-radius:20px;display:inline-block}
.po-card.p1 .po-card-badge{background:rgba(88,86,214,0.15);color:var(--po1)}
.po-card.p2 .po-card-badge{background:rgba(217,119,6,0.15);color:var(--po2)}
.po-card.p3 .po-card-badge{background:rgba(220,38,38,0.15);color:var(--po3)}
.po-card-title{font-size:16px;font-weight:700;margin-bottom:12px;color:var(--text)}
.po-card-row{font-size:13px;color:var(--text2);line-height:1.7;margin-bottom:4px}
.po-card-row b{color:var(--text);font-weight:600}
.cw-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:10px}
.cw-card{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:16px 18px;box-shadow:var(--shadow)}
.cw-word{font-size:16px;font-weight:700;color:var(--text);margin-bottom:5px}
.cw-po{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px;padding:2px 7px;border-radius:20px;display:inline-block}
.cw-po.p1{background:var(--po1-bg);color:var(--po1)}
.cw-po.p12{background:var(--po1-bg);color:var(--po1)}
.cw-po.p2{background:var(--po2-bg);color:var(--po2)}
.cw-po.p3{background:var(--po3-bg);color:var(--po3)}
.cw-def{font-size:13px;color:var(--text2);line-height:1.6}
.rules-list{display:flex;flex-direction:column;gap:10px}
.rule-card{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:16px 20px;display:flex;gap:16px;align-items:flex-start;box-shadow:var(--shadow)}
.rule-num{font-size:14px;font-weight:800;color:var(--primary);flex-shrink:0;min-width:22px}
.rule-text{font-size:14px;color:var(--text2);line-height:1.65}
.rule-text b{color:var(--text)}
.qec-big-card{background:var(--surface);border:2px solid var(--primary);border-radius:var(--radius);padding:30px 34px;box-shadow:var(--shadow-md)}
.qec-big-title{font-size:19px;font-weight:700;color:var(--primary);margin-bottom:6px;letter-spacing:-0.01em}
.qec-big-sub{font-size:14px;color:var(--text3);margin-bottom:28px;line-height:1.5}
.qec-step{display:flex;gap:18px;margin-bottom:22px;align-items:flex-start}
.qec-step:last-of-type{margin-bottom:0}
.qec-letter{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:800;flex-shrink:0}
.qec-letter.q{background:var(--po1-bg);color:var(--po1)}
.qec-letter.e{background:var(--po2-bg);color:var(--po2)}
.qec-letter.c{background:var(--green-bg);color:var(--green)}
.qec-step-title{font-size:16px;font-weight:700;color:var(--text);margin-bottom:4px}
.qec-step-body{font-size:14px;color:var(--text2);line-height:1.65}
.qec-ol{margin:10px 0 0 18px;display:flex;flex-direction:column;gap:6px}
.qec-ol li{font-size:14px;color:var(--text2);line-height:1.6}
.qec-divider{border:none;border-top:1.5px solid var(--border);margin:24px 0}
.qec-why{background:var(--surface2);border-radius:var(--radius-sm);padding:16px 20px;margin-top:20px}
.qec-why-title{font-size:14px;font-weight:700;color:var(--text);margin-bottom:8px}
.qec-why-body{font-size:14px;color:var(--text2);line-height:1.65}
.recall-rules{display:flex;flex-direction:column;gap:8px;margin-top:16px}
.recall-rule{display:flex;gap:10px;font-size:14px;color:var(--text2);line-height:1.5;padding:10px 14px;background:var(--surface2);border-radius:var(--radius-sm)}
.recall-rule-dot{color:var(--primary);font-weight:800;flex-shrink:0}
.leitner-boxes{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:24px}
.lbox{border-radius:var(--radius);padding:22px;border:2px solid}
.lbox.b1{border-color:var(--red);background:var(--red-bg)}
.lbox.b2{border-color:var(--amber);background:var(--amber-bg)}
.lbox.b3{border-color:var(--green);background:var(--green-bg)}
.lbox-num{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:6px}
.lbox.b1 .lbox-num{color:var(--red)}
.lbox.b2 .lbox-num{color:var(--amber)}
.lbox.b3 .lbox-num{color:var(--green)}
.lbox-title{font-size:15px;font-weight:700;color:var(--text);margin-bottom:4px}
.lbox-freq{font-size:13px;font-weight:600;margin-bottom:6px}
.lbox.b1 .lbox-freq{color:var(--red)}
.lbox.b2 .lbox-freq{color:var(--amber)}
.lbox.b3 .lbox-freq{color:var(--green)}
.lbox-desc{font-size:13px;color:var(--text2);line-height:1.5}
.leitner-rules-list{display:flex;flex-direction:column;gap:8px}
.l-rule{display:flex;gap:12px;font-size:14px;color:var(--text2);line-height:1.55;padding:10px 14px;background:var(--surface);border-radius:var(--radius-sm);border:1.5px solid var(--border)}
.l-rule-arrow{color:var(--primary);font-weight:700;flex-shrink:0;font-size:16px}
/* IDEAL FRAMEWORK */
.ideal-steps{display:flex;flex-direction:column;gap:10px}
.ideal-step{display:flex;gap:18px;align-items:flex-start;background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius);padding:18px 20px;box-shadow:var(--shadow)}
.ideal-letter{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:800;flex-shrink:0}
.ideal-letter.i{background:var(--po1-bg);color:var(--po1)}
.ideal-letter.d{background:var(--primary-bg);color:var(--primary)}
.ideal-letter.e{background:var(--po2-bg);color:var(--po2)}
.ideal-letter.a{background:var(--red-bg);color:var(--red)}
.ideal-letter.l{background:var(--green-bg);color:var(--green)}
.ideal-step-name{font-size:15px;font-weight:700;color:var(--text);margin-bottom:4px}
.ideal-step-desc{font-size:14px;color:var(--text2);line-height:1.65}
.ideal-step-tip{font-size:12px;color:var(--text3);margin-top:6px;font-style:italic;line-height:1.5}

/* MARK STRUCTURE COMPARISON */
.marks-comparison{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.marks-col{border-radius:var(--radius);overflow:hidden;border:1.5px solid var(--border)}
.marks-col-header{padding:14px 18px;font-size:14px;font-weight:700;color:#fff}
.marks-col.m6 .marks-col-header{background:var(--po2)}
.marks-col.m9 .marks-col-header{background:var(--po3)}
.marks-col-body{padding:14px 18px;background:var(--surface);display:flex;flex-direction:column;gap:8px}
.struct-step{display:flex;gap:10px;font-size:13px;color:var(--text2);line-height:1.5}
.struct-num{font-size:10px;font-weight:800;background:var(--surface2);border-radius:20px;padding:2px 7px;color:var(--text3);flex-shrink:0;margin-top:2px;white-space:nowrap}
.band-table{display:flex;flex-direction:column;border-radius:var(--radius-sm);overflow:hidden;margin-top:14px;border:1.5px solid var(--border)}
.band-row{display:grid;grid-template-columns:52px 1fr;font-size:12px;border-bottom:1px solid var(--border)}
.band-row:last-child{border-bottom:none}
.band-row.l3{background:var(--green-bg)}
.band-row.l2{background:var(--amber-bg)}
.band-row.l1{background:var(--red-bg)}
.band-marks{padding:10px 8px;font-weight:800;border-right:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:11px;text-align:center}
.band-row.l3 .band-marks{color:var(--green)}
.band-row.l2 .band-marks{color:var(--amber)}
.band-row.l1 .band-marks{color:var(--red)}
.band-desc{padding:10px 12px;line-height:1.5;color:var(--text2)}

/* SENTENCE STARTER BANKS */
.starter-banks{display:flex;flex-direction:column;gap:20px}
.starter-bank-title{font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:0.07em;margin-bottom:10px;padding:5px 10px;border-radius:var(--radius-sm);display:inline-block}
.starter-bank.dev .starter-bank-title{background:var(--primary-bg);color:var(--primary)}
.starter-bank.scen .starter-bank-title{background:var(--po2-bg);color:var(--po2)}
.starter-bank.conc .starter-bank-title{background:var(--green-bg);color:var(--green)}
.starters-grid{display:flex;flex-wrap:wrap;gap:8px}
.starter-chip{background:var(--surface);border:1.5px solid var(--border);border-radius:100px;padding:8px 16px;font-size:13px;color:var(--text2);cursor:pointer;transition:var(--t);font-family:var(--font);text-align:left;box-shadow:var(--shadow);line-height:1.4}
.starter-bank.dev .starter-chip:hover{border-color:var(--primary);background:var(--primary-bg);color:var(--primary-dark)}
.starter-bank.scen .starter-chip:hover{border-color:var(--po2);background:var(--po2-bg);color:var(--po2)}
.starter-bank.conc .starter-chip:hover{border-color:var(--green);background:var(--green-bg);color:var(--green)}
.starter-chip.copied{background:var(--green)!important;border-color:var(--green)!important;color:#fff!important}

/* COMMON MISTAKES */
.mistakes-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.mistakes-col{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow)}
.mistakes-col-header{padding:12px 18px;font-size:13px;font-weight:700;color:#fff}
.mistakes-col.m6 .mistakes-col-header{background:var(--po2)}
.mistakes-col.m9 .mistakes-col-header{background:var(--po3)}
.mistake-list{padding:12px 16px;display:flex;flex-direction:column;gap:8px}
.mistake-item{display:flex;gap:10px;font-size:13px;color:var(--text2);line-height:1.5;padding:6px 0;border-bottom:1px solid var(--border)}
.mistake-item:last-child{border-bottom:none}
.mistake-x{color:var(--red);font-weight:800;flex-shrink:0;font-size:14px}

/* ANSWER PLANNER VIEW */
#planner-view.active{flex-direction:column;overflow-y:auto;padding:32px}
.planner-content{max-width:880px;width:100%;margin:0 auto;display:flex;flex-direction:column;gap:20px;padding-bottom:48px}
.planner-setup{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius);padding:28px 32px;box-shadow:var(--shadow-md)}
.planner-setup-title{font-size:20px;font-weight:700;color:var(--text);margin-bottom:4px}
.planner-setup-sub{font-size:14px;color:var(--text3);margin-bottom:24px;line-height:1.6}
.planner-marks-picker{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:20px}
.planner-mark-btn{padding:20px;border:2px solid var(--border);border-radius:var(--radius);background:var(--surface);cursor:pointer;font-family:var(--font);transition:var(--t);text-align:center;box-shadow:var(--shadow)}
.planner-mark-btn:hover{border-color:var(--po3);transform:translateY(-1px)}
.planner-mark-btn.sel.m6{border-color:var(--po2);background:var(--po2-bg)}
.planner-mark-btn.sel.m9{border-color:var(--po3);background:var(--po3-bg)}
.planner-mark-num{font-size:32px;font-weight:800;color:var(--text);line-height:1}
.planner-mark-btn.sel.m6 .planner-mark-num{color:var(--po2)}
.planner-mark-btn.sel.m9 .planner-mark-num{color:var(--po3)}
.planner-mark-lbl{font-size:13px;color:var(--text3);margin-top:4px}
.planner-mark-steps{font-size:11px;font-weight:700;letter-spacing:0.04em;margin-top:6px;color:var(--text3)}
/* Progress tracker */
.planner-progress{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius);padding:14px 18px;display:flex;gap:8px;align-items:center;flex-wrap:wrap;box-shadow:var(--shadow)}
.progress-step{display:flex;align-items:center;gap:5px;padding:6px 12px;border-radius:100px;border:1.5px solid var(--border);background:var(--surface2);cursor:pointer;transition:var(--t);font-size:12px;font-weight:700;color:var(--text3);user-select:none}
.progress-step:hover{border-color:var(--primary);color:var(--primary);background:var(--primary-bg)}
.progress-step.done{background:var(--green-bg);border-color:var(--green);color:var(--green)}
.progress-check{width:15px;height:15px;border-radius:50%;border:2px solid currentColor;display:flex;align-items:center;justify-content:center;font-size:8px;flex-shrink:0;transition:var(--t)}
.progress-step.done .progress-check{background:var(--green);border-color:var(--green);color:#fff}
/* Stage cards */
.planner-stage{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:var(--shadow);transition:border-color 200ms}
.planner-stage.done{border-color:var(--green)}
.stage-header{padding:14px 18px;display:flex;align-items:center;gap:14px}
.stage-header.si{background:var(--po1-bg);border-bottom:1px solid rgba(88,86,214,0.15)}
.stage-header.sd{background:var(--primary-bg);border-bottom:1px solid rgba(59,130,246,0.15)}
.stage-header.sa{background:var(--red-bg);border-bottom:1px solid rgba(220,38,38,0.15)}
.stage-header.sl{background:var(--green-bg);border-bottom:1px solid rgba(22,163,74,0.15)}
.stage-badge{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:800;flex-shrink:0}
.stage-badge.si{background:rgba(88,86,214,0.15);color:var(--po1)}
.stage-badge.sd{background:rgba(59,130,246,0.15);color:var(--primary)}
.stage-badge.sa{background:rgba(220,38,38,0.15);color:var(--red)}
.stage-badge.sl{background:rgba(22,163,74,0.15);color:var(--green)}
.stage-info{flex:1;min-width:0}
.stage-name{font-size:14px;font-weight:700;color:var(--text)}
.stage-hint{font-size:12px;color:var(--text3);margin-top:2px;line-height:1.4}
.stage-check-label{display:flex;align-items:center;gap:6px;font-size:12px;font-weight:600;color:var(--text3);cursor:pointer;user-select:none;padding:6px 10px;border-radius:var(--radius-sm);border:1.5px solid var(--border);background:var(--surface);transition:var(--t);flex-shrink:0;white-space:nowrap}
.stage-check-label:hover{border-color:var(--green);color:var(--green);background:var(--green-bg)}
.stage-check-label input{cursor:pointer;accent-color:var(--green)}
.stage-body{padding:16px 18px;display:flex;flex-direction:column;gap:14px}
.stage-section-lbl{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:var(--text3);margin-bottom:6px}
.stage-skeleton-box{background:var(--surface2);border-radius:var(--radius-sm);padding:11px 14px;display:flex;gap:10px;align-items:flex-start}
.stage-skeleton-text{flex:1;font-size:13px;color:var(--text2);line-height:1.65;font-style:italic}
.stage-copy-btn{flex-shrink:0;background:var(--surface);border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:5px 11px;font-size:12px;font-weight:600;color:var(--text3);cursor:pointer;transition:var(--t);font-family:var(--font);white-space:nowrap}
.stage-copy-btn:hover{border-color:var(--primary);color:var(--primary);background:var(--primary-bg)}
.stage-copy-btn.copied{background:var(--green)!important;border-color:var(--green)!important;color:#fff!important}
.stage-chips{display:flex;flex-wrap:wrap;gap:6px}
.stage-chip{background:var(--surface);border:1.5px solid var(--border);border-radius:100px;padding:6px 13px;font-size:12px;color:var(--text2);cursor:pointer;transition:var(--t);font-family:var(--font);box-shadow:var(--shadow);line-height:1.4;text-align:left}
.stage-chip:hover{border-color:var(--primary);background:var(--primary-bg);color:var(--primary-dark)}
.stage-chip.copied{background:var(--green)!important;border-color:var(--green)!important;color:#fff!important}
.stage-textarea{width:100%;min-height:80px;resize:vertical;border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:11px 13px;font-size:14px;font-family:var(--font);color:var(--text);background:var(--surface);line-height:1.65;transition:var(--t)}
