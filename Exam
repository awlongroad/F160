// =============================================================
// LOGIC
// =============================================================
function getTemplates(){
  if(!S.sub||S.po===null)return[];
  const sub=SUBTOPICS[S.sub];
  return TEMPLATES.filter(t=>{
    if(t.po!==S.po)return false;
    if(!sub.allowed.includes(t.id))return false;
    if(t.needsCT){
      return sub.items.some(it=>t.ctCompat.some(c=>it.types.includes(c)));
    }
    return true;
  });
}

function getItems(tmpl){
  if(!S.sub)return[];
  const sub=SUBTOPICS[S.sub];
  if(!tmpl||!tmpl.needsCT)return sub.items;
  return sub.items.filter(it=>tmpl.ctCompat.some(c=>it.types.includes(c)));
}

function getContentTypes(tmpl,item){
  if(!tmpl||!item||!tmpl.needsCT)return[];
  return tmpl.ctCompat.filter(c=>item.types.includes(c));
}

function buildQuestion(){
  const t=S.tmpl, it=S.item, itB=S.itemB, ct=S.ct, n=S.number, sc=S.scenario;
  const marks=t.marksCalc(n,S.marks);
  let html='',plain='';

  const label=(itemObj,useTerm=false)=>useTerm?itemObj.term:itemObj.label;
  const nw=n?NUM_WORDS[n]:'';
  const ctMeta=ct?CT[ct]:null;
  const typeS=ctMeta?ctMeta.s:'';
  const typeP=ctMeta?ctMeta.p:'';
  const typePre=ctMeta?ctMeta.pre:'of';
  const typeLabel=n===1?typeS:typeP;

  switch(t.id){
    case 'T1':
      html=`State <strong>${nw}</strong> ${typeLabel} ${typePre} ${label(it)}`;
      plain=`State ${nw} ${typeLabel} ${typePre} ${label(it)}`;
      break;
    case 'T2':
      html=`Outline <strong>ONE</strong> ${typeS} ${typePre} ${label(it)}`;
      plain=`Outline ONE ${typeS} ${typePre} ${label(it)}`;
      break;
    case 'T3':
      html=`Define the term '${label(it,true)}'`;
      plain=`Define the term '${label(it,true)}'`;
      break;
    case 'T4':
      if(ct==='importance'){
        html=`Explain the importance of ${label(it)}`;
        plain=`Explain the importance of ${label(it)}`;
      } else {
        html=`Explain the ${typeP} of ${label(it)}`;
        plain=`Explain the ${typeP} of ${label(it)}`;
      }
      break;
    case 'T5':
      html=`Identify <strong>${nw}</strong> ${typeLabel} of ${label(it)} from the scenario`;
      plain=`Identify ${nw} ${typeLabel} of ${label(it)} from the scenario`;
      break;
    case 'T6':
      if(ct==='importance'){
        html=`Explain the importance of ${label(it)} for ${sc}`;
        plain=`Explain the importance of ${label(it)} for ${sc}`;
      } else {
        html=`Explain <strong>${nw}</strong> ${typeLabel} ${typePre} ${label(it)} for ${sc}`;
        plain=`Explain ${nw} ${typeLabel} ${typePre} ${label(it)} for ${sc}`;
      }
      break;
    case 'T7':
      html=`Describe <strong>${nw}</strong> ${typeLabel} ${typePre} ${label(it)} for ${sc}`;
      plain=`Describe ${nw} ${typeLabel} ${typePre} ${label(it)} for ${sc}`;
      break;
    case 'T8':
      html=`Compare ${label(it)} and ${label(itB)} for ${sc}`;
      plain=`Compare ${label(it)} and ${label(itB)} for ${sc}`;
      break;
    case 'T9':
      html=`Analyse the impact of ${label(it)} on ${sc}`;
      plain=`Analyse the impact of ${label(it)} on ${sc}`;
      break;
    case 'T10':
      html=`Discuss the suitability of ${label(it)} for ${sc}`;
      plain=`Discuss the suitability of ${label(it)} for ${sc}`;
      break;
    case 'T11':
      html=`Justify a recommendation of ${label(it)} for ${sc}`;
      plain=`Justify a recommendation of ${label(it)} for ${sc}`;
      break;
  }
  return{html:`${html} [${marks}]`,plain:`${plain} [${marks}]`,marks,po:t.po,verb:t.verb,tmplId:t.id,
    sub:S.sub,subLabel:SUBTOPICS[S.sub].label,
    buildState:{ta:S.ta,sub:S.sub,po:S.po,tmplId:t.id,
      itemId:S.item?.id||null,itemBId:S.itemB?.id||null,
      ct:S.ct,number:S.number,marks:S.marks,scenario:S.scenario}};
}

function isReadyToPreview(){
  const t=S.tmpl;
  if(!t)return false;
  if(t.needsItem&&!S.item)return false;
  if(t.needsItemB&&!S.itemB)return false;
  if(t.needsCT&&!S.ct)return false;
  if(t.needsNumber&&!S.number)return false;
  if(t.needsScenario&&!S.scenario)return false;
  if(t.needsMarks&&!S.marks)return false;
  return true;
}

