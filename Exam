function render(){
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.toggle('active',b.dataset.tab===S.view));
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.getElementById(S.view+'-view').classList.add('active');
  if(S.view==='generator'){renderBreadcrumb();renderStep();renderList();}
  else if(S.view==='support'){renderSupport();}
  else if(S.view==='planner'){renderPlanner();}
}

function switchView(v){S.view=v;render();}
function setSupportSection(key){S.supportSection=key;renderSupport();}

function renderBreadcrumb(){
  const bc=document.getElementById('breadcrumb');
  const parts=[];
  if(S.ta){
    const ta=TOPIC_AREAS.find(t=>t.id===S.ta);
    parts.push({label:S.ta,full:ta?.label,step:1});
  }
  if(S.sub){
    parts.push({label:S.sub,full:SUBTOPICS[S.sub]?.label,step:2});
  }
  if(S.po){
    parts.push({label:`PO${S.po}`,step:3});
  }
  if(S.tmpl){
    parts.push({label:S.tmpl.verb,step:4});
  }
  if(parts.length===0){bc.innerHTML='';return;}
  bc.innerHTML=parts.map((p,i)=>{
    const isLast=i===parts.length-1;
    const title=p.full?`title="${p.full}"`:'';
    const cls=isLast?'crumb active':'crumb link';
    const onclick=isLast?'':`onclick="goToStep(${p.step})"`;
    return `${i>0?'<span class="crumb-sep">›</span>':''}<span class="${cls}" ${title} ${onclick}>${p.label}</span>`;
  }).join('');
}

function goToStep(n){
  if(n<=1){S.ta=null;S.sub=null;S.po=null;S.tmpl=null;S.item=null;S.itemB=null;S.ct=null;S.number=null;S.marks=null;S.scenario=null;S.editingIdx=null;}
  else if(n<=2){S.sub=null;S.po=null;S.tmpl=null;S.item=null;S.itemB=null;S.ct=null;S.number=null;S.marks=null;S.scenario=null;S.editingIdx=null;}
  else if(n<=3){S.po=null;S.tmpl=null;S.item=null;S.itemB=null;S.ct=null;S.number=null;S.marks=null;S.scenario=null;}
  else if(n<=4){S.tmpl=null;S.item=null;S.itemB=null;S.ct=null;S.number=null;S.marks=null;S.scenario=null;}
  S.step=n;
  render();
}

function renderStep(){
  const sc=document.getElementById('step-content');
  sc.innerHTML='';
  const wrap=document.createElement('div');
  wrap.className='step-wrapper';
  sc.appendChild(wrap);

  switch(S.step){
    case 1: renderStep1(wrap);break;
    case 2: renderStep2(wrap);break;
    case 3: renderStep3(wrap);break;
    case 4: renderStep4(wrap);break;
    case 5: renderStep5(wrap);break;
    case 6: renderStep6(wrap);break;
  }
}

