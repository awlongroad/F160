              <div class="stage-skeleton-text">${st.skeleton}</div>
              <button class="stage-copy-btn" onclick="copyChip(this,'${st.skeleton.replace(/'/g,'&#39;').replace(/"/g,'&quot;')}')">Copy</button>
            </div>`:''}
            ${st.starters&&st.starters.length>0?`<div class="stage-section-lbl" style="margin-top:${st.skeleton?'12px':'0'}">Sentence starters — click to copy</div>
            <div class="stage-chips">
              ${st.starters.map(s=>`<button class="stage-chip" onclick="copyChip(this,this.dataset.t)" data-t="${s.replace(/"/g,'&quot;').replace(/'/g,'&#39;')}">${s}</button>`).join('')}
            </div>`:''}
          </div>
          <div class="write-prompt">
            <span style="font-size:18px;flex-shrink:0">✏️</span>
            <div>Write the <strong>${st.label}</strong> section in your <strong>Word document</strong> or <strong>exercise book</strong>, then come back and tick <strong>Done ✓</strong> when complete.</div>
          </div>`}
        </div>
      </div>`).join('')}

    <div class="planner-actions">
      <button class="btn btn-ghost btn-sm" id="copy-skel-btn2" onclick="plannerCopySkeleton()">Copy full blank skeleton</button>
      <div class="planner-wc">Target: <b>${targetWords}</b></div>
    </div>
    <div class="recall-note">
      <strong>Building towards exam confidence:</strong> The Guided Mode gives you the structure when you are still learning. Once you feel familiar with it, switch to <strong>Memory Mode</strong> (🧠 above) and practice without the starters or templates — this is how you should be revising in the final weeks before the exam. The starters are training wheels, not a permanent fixture.
    </div>`;
}

function plannerPickQ(val){
  S.planner.question=val;
  const q=S.questions.find(q2=>q2.plain===val);
  if(q){S.planner.po=q.po;S.planner.verb=q.verb||(TEMPLATES.find(t=>t.id===q.tmplId)||{}).verb||null;S.planner.marks=q.marks;}
  renderPlanner();
}
function plannerSetPO(po){S.planner.po=po;S.planner.verb=null;S.planner.marks=null;renderPlanner();}
function plannerSetVerb(v){S.planner.verb=v;S.planner.marks=null;renderPlanner();}
function plannerSetMarks(m){S.planner.marks=m;renderPlanner();}
function plannerTogglePractice(){S.planner.practiceMode=!S.planner.practiceMode;renderPlanner();}
function plannerStart(){
  if(!S.planner.po)return;
  if(S.planner.po!==3&&!S.planner.verb)return;
  if(!S.planner.marks)return;
  S.planner.active=true;
  S.planner.practiceMode=false;
  S.planner.checks={};
  renderPlanner();
}
function plannerToggle(key){
  S.planner.checks[key]=!S.planner.checks[key];
  renderPlanner();
}
function plannerReset(){S.planner.active=false;renderPlanner();}

function copyChip(btn,text){
  const t=text||btn.dataset.t||btn.textContent;
  navigator.clipboard.writeText(t).then(()=>{
    const o=btn.textContent;
    btn.textContent='Copied!';
    btn.classList.add('copied');
    setTimeout(()=>{btn.textContent=o;btn.classList.remove('copied');},1500);
  });
}
function plannerCopySkeleton(){
  const p=S.planner;
  const text=getPlannerSkeleton(p.po||3,p.verb,p.marks||(p.po===3?6:1));
  navigator.clipboard.writeText(text).then(()=>{
    ['copy-skel-btn','copy-skel-btn2'].forEach(id=>{
      const b=document.getElementById(id);
      if(b){const o=b.textContent;b.textContent='Copied!';b.style.background='var(--green)';b.style.color='#fff';setTimeout(()=>{b.textContent=o;b.style.background='';b.style.color='';},1500);}
    });
  });
}

// =============================================================
// SENTENCE STARTER COPY
// =============================================================
function copyStarter(btn){
  const text=btn.textContent;
  navigator.clipboard.writeText(text).then(()=>{
    btn.textContent='Copied!';
    btn.classList.add('copied');
    setTimeout(()=>{btn.textContent=text;btn.classList.remove('copied');},1500);
  });
}

// =============================================================
// DEFAULT SCENARIO
// =============================================================
function setDefaultScenario(val){
  S.defaultScenario=val||null;
  if(S.tmpl&&S.tmpl.needsScenario&&!S.scenario&&S.defaultScenario){
    S.scenario=S.defaultScenario;
    if(S.step===5||S.step===6)render();
  }
}

// =============================================================
// CLIENT CONTEXT
// =============================================================
function setContext(dimId, val){
  if(S.context[dimId]===val){
    delete S.context[dimId];
  } else {
    S.context[dimId]=val;
  }
  // Update pill appearance
  document.querySelectorAll(`.ctx-pill[data-dim="${dimId}"]`).forEach(p=>{
    p.classList.toggle('sel', p.dataset.val===S.context[dimId]);
  });
  // Update active count badge
  updateCtxCount();
  // Refresh preview if visible
  if(S.view==='generator'&&S.step===6)renderStep();
}

function toggleCtxPanel(){
  S.ctxOpen=!S.ctxOpen;
  const builder=document.getElementById('ctx-builder');
  const chevron=document.getElementById('ctx-chevron');
  if(builder)builder.style.display=S.ctxOpen?'':'none';
  if(chevron)chevron.classList.toggle('open',S.ctxOpen);
}

function updateCtxCount(){
  const count=Object.keys(S.context).length;
  const badge=document.getElementById('ctx-active-count');
  if(!badge)return;
  if(count>0){
    badge.textContent=count;
    badge.style.display='';
  } else {
    badge.style.display='none';
  }
}

function buildClientBrief(){
  const activeCount=Object.keys(S.context).length;
  const items=CONTEXT_DIMENSIONS
    .filter(d=>S.context[d.id])
    .map(d=>{
      const opt=d.options.find(o=>o.value===S.context[d.id]);
      const label=opt?opt.label:S.context[d.id];
      return `<div class="brief-item"><span class="brief-item-key">${d.label}</span><span class="brief-item-val">${label}</span></div>`;
    }).join('');
  const body=activeCount>0
    ? items
    : `<span class="brief-none">No context set — use the Client Context panel in the sidebar to add client requirements.</span>`;
  return `<div class="client-brief">
    <div class="client-brief-header">&#128203; Client Brief</div>
    <div class="client-brief-body">${body}</div>
  </div>`;
}

function contextForCopy(){
  const dims=CONTEXT_DIMENSIONS.filter(d=>S.context[d.id]);
  if(!dims.length)return'';
  return'\n\nClient Context:\n'+dims.map(d=>{
    const opt=d.options.find(o=>o.value===S.context[d.id]);
    return`  ${d.label}: ${opt?opt.label:S.context[d.id]}`;
  }).join('\n');
}

// =============================================================
// INIT
// =============================================================
(function initSidebar(){
  // Scenario select
  const sel=document.getElementById('default-scenario-sel');
  if(sel)sel.innerHTML='<option value="">Per question (no default)</option>'+
    SCENARIOS.map(sc=>`<option value="${sc.replace(/"/g,'&quot;')}">${sc}</option>`).join('');
  // Context builder pills
  const builder=document.getElementById('ctx-builder');
  if(builder){
    builder.innerHTML=CONTEXT_DIMENSIONS.map(d=>`
      <div>
        <div class="ctx-dim-label">${d.icon}&nbsp;${d.label}</div>
        <div class="ctx-pills">${d.options.map(o=>`<button class="ctx-pill" data-dim="${d.id}" data-val="${o.value.replace(/"/g,'&quot;')}" onclick="setContext('${d.id}','${o.value.replace(/\\/g,'\\\\').replace(/'/g,"\\'")}')">  ${o.label}</button>`).join('')}</div>
      </div>`).join('');
  }
})();
render();
</script>
</body>
</html>
