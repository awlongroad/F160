function renderList(){
  const ql=document.getElementById('question-list');
  const cnt=document.getElementById('sidebar-count');
  const copyBtn=document.getElementById('copy-all-btn');
  const qsBtn=document.getElementById('qs-btn');
  const copyOpts=document.getElementById('copy-opts');
  const qCount=S.questions.length;
  const totalMarks=S.questions.reduce((s,q)=>s+q.marks,0);
  cnt.textContent=qCount===0?'0 questions':`${qCount} question${qCount!==1?'s':''} · ${totalMarks} mark${totalMarks!==1?'s':''}`;
  copyBtn.disabled=qCount===0;
  qsBtn.disabled=qCount===0;
  if(copyOpts)copyOpts.style.display=qCount===0?'none':'';

  if(qCount===0){
    ql.innerHTML=`<div class="q-empty"><div class="q-empty-icon">&#9998;</div><div>Questions you build will<br>appear here.</div></div>`;
    return;
  }
  ql.innerHTML=S.questions.map((q,i)=>`
    <div class="q-item${S.editingIdx===i?' editing':''}" draggable="true" data-idx="${i}"
      ondragstart="dragStart(event,${i})" ondragover="dragOver(event,${i})"
      ondrop="dragDrop(event,${i})" ondragend="dragEnd()">
      <div class="q-handle">&#8942;&#8942;</div>
      <div class="q-body">
        <div class="q-badges">
          <span class="q-num">${i+1}</span>
          <span class="po-badge po${q.po}">PO${q.po}</span>
          <span class="mark-chip">[${q.marks}]</span>
        </div>
        <div class="q-text">${q.plain}</div>
      </div>
      <button class="q-edit" onclick="editQuestion(${i})" title="Edit">&#9998;</button>
      <button class="q-del" onclick="deleteQ(${i})" title="Delete">&#10005;</button>
    </div>`).join('');
}

// =============================================================
// EVENT HANDLERS
// =============================================================
document.querySelectorAll('.tab-btn').forEach(b=>{
  b.addEventListener('click',()=>switchView(b.dataset.tab));
});

function selectTA(id){S.ta=id;S.step=2;render();}
function selectSub(id){S.sub=id;S.step=3;render();}
function selectPO(po){S.po=po;S.tmpl=null;S.item=null;S.itemB=null;S.ct=null;S.number=null;S.marks=null;S.scenario=null;S.step=4;render();}
function selectTemplate(id){
  const t=TEMPLATES.find(x=>x.id===id);
  S.tmpl=t;
  S.item=null;S.itemB=null;S.ct=null;S.number=null;S.marks=null;
  S.scenario=(t.needsScenario&&S.defaultScenario)?S.defaultScenario:null;
  S.step=5;render();
}
function selectItem(id){
  const sub=SUBTOPICS[S.sub];
  S.item=sub.items.find(it=>it.id===id)||null;
  S.ct=null;S.itemB=null;
  S.step=5;render();
}
function selectItemB(id){
  const sub=SUBTOPICS[S.sub];
  S.itemB=sub.items.find(it=>it.id===id)||null;
  S.step=5;render();
}
function selectCT(ct){S.ct=ct||null;S.step=5;render();}
function selectNumber(n){S.number=n;S.step=5;render();}
function selectMarks(m){S.marks=m;S.step=5;render();}
function selectScenario(sc){S.scenario=sc||null;S.step=5;render();}
function goPreview(){if(isReadyToPreview()){S.step=6;render();}}

function addQuestion(){
  const q=buildQuestion();
  if(S.editingIdx!==null){
    const idx=S.editingIdx;
    S.questions[idx]=q;
    S.editingIdx=null;
    S.step=4;
    S.item=null;S.itemB=null;S.ct=null;S.number=null;S.marks=null;S.scenario=null;
    render();
    setTimeout(()=>{
      const items=document.querySelectorAll('.q-item');
      if(items[idx])items[idx].classList.add('pulse-green');
    },50);
  } else {
    S.questions.push(q);
    S.step=4;
    S.item=null;S.itemB=null;S.ct=null;S.number=null;S.marks=null;S.scenario=null;
    render();
    setTimeout(()=>{
      const items=document.querySelectorAll('.q-item');
      const last=items[items.length-1];
      if(last)last.classList.add('pulse-green');
    },50);
  }
}

function deleteQ(i){
  if(S.editingIdx===i){
    S.editingIdx=null;
    S.questions.splice(i,1);
    render();
  } else {
    if(S.editingIdx!==null&&i<S.editingIdx)S.editingIdx--;
    S.questions.splice(i,1);
    renderList();
  }
}

function clearAll(){
  if(S.questions.length===0)return;
  if(confirm(`Remove all ${S.questions.length} question(s)?`)){
    S.questions=[];renderList();
  }
}

function copyAll(){
  const ctx=contextForCopy();
  let text=(ctx?`--- Client Context ---${ctx}\n\n--- Questions ---\n\n`:'');
  text+=S.questions.map((q,i)=>{
    let line=`${i+1}. ${q.plain}`;
    if(S.copySubtopic&&q.sub)line+=`\n   [${q.sub} — ${q.subLabel}]`;
    return line;
  }).join('\n\n');
  if(S.copyTotals){
    const total=S.questions.reduce((s,q)=>s+q.marks,0);
    text+=`\n\n---\nTotal: ${S.questions.length} question${S.questions.length!==1?'s':''} · ${total} mark${total!==1?'s':''}`;
  }
  navigator.clipboard.writeText(text).then(()=>{
    const btn=document.getElementById('copy-all-btn');
    const orig=btn.textContent;
    btn.textContent='Copied!';
    btn.style.background='var(--green)';
    setTimeout(()=>{btn.textContent=orig;btn.style.background='';},2000);
  });
}

// DRAG AND DROP
function dragStart(e,i){S.dragSrc=i;e.currentTarget.classList.add('dragging');}
function dragOver(e,i){e.preventDefault();document.querySelectorAll('.q-item').forEach(el=>el.classList.remove('drag-over'));if(i!==S.dragSrc)e.currentTarget.classList.add('drag-over');}
function dragDrop(e,i){
  e.preventDefault();
  if(S.dragSrc===null||S.dragSrc===i)return;
  const items=[...S.questions];
  const [moved]=items.splice(S.dragSrc,1);
  items.splice(i,0,moved);
  S.questions=items;
  renderList();
}
function dragEnd(){S.dragSrc=null;document.querySelectorAll('.q-item').forEach(el=>{el.classList.remove('dragging');el.classList.remove('drag-over');});}

