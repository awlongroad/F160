// QUESTION PAPER SORTER (LEITNER)
// =============================================================
function openQSorter(){
  if(!S.questions.length)return;
  S.qSorter.queue=[...S.questions];
  S.qSorter.buckets={box1:[],box2:[],box3:[]};
  S.qSorter.done=false;
  S.qSorter.open=true;
  document.getElementById('qs-modal').classList.remove('hidden');
  renderQSorter();
}
function closeQSorter(){
  S.qSorter.open=false;
  document.getElementById('qs-modal').classList.add('hidden');
}
function sortQCard(box){
  if(!S.qSorter.queue.length)return;
  const q=S.qSorter.queue.shift();
  ['box1','box2','box3'].forEach(b=>{
    S.qSorter.buckets[b]=S.qSorter.buckets[b].filter(x=>x.plain!==q.plain);
  });
  S.qSorter.buckets[box].push(q);
  if(!S.qSorter.queue.length)S.qSorter.done=true;
  renderQSorter();
}
function restartQSorter(){
  S.qSorter.queue=[...S.questions];
  S.qSorter.done=false;
  renderQSorter();
}
function copyQBox(box){
  const items=S.qSorter.buckets[box];
  const text=items.map((q,i)=>`${i+1}. ${q.plain}`).join('\n\n');
  navigator.clipboard.writeText(text).then(()=>{
    const btn=document.querySelector(`[data-qbox="${box}"]`);
    if(btn){const o=btn.textContent;btn.textContent='Copied!';setTimeout(()=>btn.textContent=o,1500);}
  });
}
function renderQSorter(){
  const body=document.getElementById('qs-modal-body');
  if(!body)return;
  const qs=S.qSorter;
  const sorted=Object.values(qs.buckets).flat().length;
  const total=qs.queue.length+sorted;

  if(qs.done||(!qs.queue.length&&sorted>0)){
    const boxCfg=[
      {id:'box1',label:'Box 1 – Review Every Session',cls:'box1',desc:"Don't Know — study these first, every session"},
      {id:'box2',label:'Box 2 – Review Every Other Session',cls:'box2',desc:'Unsure — nearly there, keep practising'},
      {id:'box3',label:'Box 3 – Review Weekly',cls:'box3',desc:'Confident — maintain with spaced review'},
    ];
    body.innerHTML=`
      <div class="leitner-tip">
        <strong>The Leitner System:</strong> Focus each study session on <strong>Box 1</strong> first, then Box 2, then Box 3.
        If you get a Box 3 question wrong in a later session, move it straight back to Box 1.
        The goal is to move every question to Box 3 through repeated, spaced practice.
      </div>
      <div class="qs-boxes">
        ${boxCfg.map(b=>{
          const items=qs.buckets[b.id];
          return`<div class="qs-box ${b.cls}">
            <div class="qs-box-hdr">
              <div>
                <div class="qs-box-label">${b.label}</div>
                <div style="font-size:11px;color:var(--text3);margin-top:2px">${b.desc}</div>
              </div>
              <span class="qs-box-cnt">${items.length}</span>
            </div>
            <div class="qs-box-body">
              ${items.length===0?'<div style="font-size:12px;color:var(--text3);padding:6px">None here.</div>':
                items.map(q=>`<div class="qs-box-item">${q.plain}</div>`).join('')}
            </div>
            ${items.length>0?`<div style="padding:8px 10px;border-top:1px solid var(--border)"><button class="btn btn-ghost btn-sm btn-full" data-qbox="${b.id}" onclick="copyQBox('${b.id}')">Copy this box</button></div>`:''}
          </div>`;
        }).join('')}
      </div>
      <div style="display:flex;gap:8px;justify-content:center;margin-top:8px">
        <button class="btn btn-ghost" onclick="restartQSorter()">Sort Again</button>
        <button class="btn btn-ghost" onclick="closeQSorter()">Close</button>
      </div>`;
    return;
  }

  const q=qs.queue[0];
  body.innerHTML=`
    <div style="text-align:center;font-size:14px;color:var(--text3);margin-bottom:16px">
      Question <strong>${sorted+1}</strong> of <strong>${total}</strong>
    </div>
    <div class="qs-card">
      <div class="qs-card-po"><span class="po-badge po${q.po}">PO${q.po}</span> &nbsp; [${q.marks} marks]</div>
      <div class="qs-card-q">${q.html}</div>
    </div>
    <div class="qs-sort-btns">
      <button class="qs-sort-btn box1" onclick="sortQCard('box1')">
        <span>Don't Know</span><span class="qs-sort-btn-sub">Box 1 – Review every session</span>
      </button>
      <button class="qs-sort-btn box2" onclick="sortQCard('box2')">
        <span>Unsure</span><span class="qs-sort-btn-sub">Box 2 – Review every other session</span>
      </button>
      <button class="qs-sort-btn box3" onclick="sortQCard('box3')">
        <span>Confident</span><span class="qs-sort-btn-sub">Box 3 – Review weekly</span>
      </button>
    </div>
    <div style="text-align:center;margin-top:8px">
      <button class="btn btn-ghost btn-sm" onclick="closeQSorter()">Save &amp; Close</button>
    </div>`;
}

