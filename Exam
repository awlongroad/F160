        <button class="btn btn-ghost btn-sm btn-full" id="qs-btn" disabled onclick="openQSorter()">Sort by Confidence (Leitner)</button>
        <button class="btn btn-ghost btn-sm btn-full" onclick="clearAll()">Clear List</button>
      </div>
    </aside>

    <div class="gen-content">
      <nav class="breadcrumb" id="breadcrumb"></nav>
      <div id="step-content"></div>
    </div>
  </section>

  <!-- EXAM SUPPORT VIEW -->
  <section id="support-view" class="view">
    <div id="support-content" class="support-content"></div>
  </section>

  <!-- ANSWER PLANNER VIEW -->
  <section id="planner-view" class="view">
    <div id="planner-content" class="planner-content"></div>
  </section>

</main>

<!-- PAPER SORTER MODAL -->
<div id="qs-modal" class="modal hidden">
