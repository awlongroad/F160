    <div class="preview-meta">
      <div class="preview-meta-item">Performance Objective: <b>PO${q.po}</b></div>
      <div class="preview-meta-item">Marks: <b>[${q.marks}]</b></div>
      <div class="preview-meta-item">Subtopic: <b>${S.sub} — ${SUBTOPICS[S.sub].label}</b></div>
