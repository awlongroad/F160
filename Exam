// =============================================================
// EDIT QUESTION / NAV HELPERS
// =============================================================
function renderNav(step){
  if(step<=1)return'';
  const labels={2:'Topics',3:'Subtopics',4:'PO Level',5:'Template',6:'Configure'};
  const showHome=step>2;
  return`<div class="step-nav">
    <button class="nav-back-btn" onclick="goToStep(${step-1})">&#8592; ${labels[step]}</button>
    ${showHome?`<button class="nav-home-btn" onclick="goToStep(1)">&#8962; Start over</button>`:''}
  </div>`;
}

function editQuestion(i){
  const q=S.questions[i];
  if(!q||!q.buildState)return;
  const bs=q.buildState;
  S.ta=bs.ta;
  S.sub=bs.sub;
  S.po=bs.po;
  S.tmpl=TEMPLATES.find(t=>t.id===bs.tmplId)||null;
  S.item=bs.itemId?SUBTOPICS[bs.sub].items.find(it=>it.id===bs.itemId)||null:null;
  S.itemB=bs.itemBId?SUBTOPICS[bs.sub].items.find(it=>it.id===bs.itemBId)||null:null;
  S.ct=bs.ct;
  S.number=bs.number;
  S.marks=bs.marks;
  S.scenario=bs.scenario;
  S.editingIdx=i;
  S.step=5;
  render();
}

function cancelEdit(){
  S.editingIdx=null;
  render();
}

// =============================================================
// QUESTION PREVIEW TIP BUILDERS
// =============================================================
function cwDef(verb){
  return({State:'Give short, factual answers. No explanation needed.',Define:'Give the exact, precise meaning of a term.',Outline:'Give a brief account — more than a list item, less than a full explanation.',Explain:'Give reasons or causes. Use "because" or "this means that" to develop each point.',Identify:'Name or provide features or factors from the given scenario.',Describe:'Give an account of relevant characteristics as they relate to the scenario.',Compare:'Give an account of similarities and differences between two items.',Analyse:'Break information into parts using a logical chain of reasoning.',Discuss:'Present and evaluate points for and against to reach a reasoned judgement.',Justify:'Give evidence and reasoning to support a recommendation.'})[verb]||'Respond precisely to the demand of the question.';
}

function buildQECTip(){
  return`<div class="qec-tip">
    <div class="qec-tip-icon">&#9432;</div>
    <div class="qec-tip-text">
      <strong>Active Recall (QEC):</strong> This question is your <strong>Q</strong>.
      Next — create your <strong>E</strong>vidence: write a mark scheme from your course materials.
      Then close everything, write a full answer from memory, and check it against your evidence (<strong>C</strong>onclusion).
      <span class="qec-link" onclick="S.supportSection='qec';switchView('support')">Full guide in Exam Support &#8594;</span>
    </div>
  </div>`;
}

function buildPO1Tip(q){
  const verb=q.verb||'';
  const pe=q.plain.replace(/\\/g,'\\\\').replace(/'/g,"\\'");
  const rules={
    State:['Each mark = one distinct point. Give exactly as many points as there are marks.','Every point must be different — no merging two ideas into one answer.','Use subject-specific vocabulary. Technical terms earn more than generic descriptions.','No explanation needed — just state the fact, term, or characteristic clearly.'],
    Define:['Give the precise meaning of the term — not an example of it.','Avoid circular definitions: do not use the term itself in your definition.','For 2 marks: core meaning (1 mark) + a qualifying detail or distinguishing feature (1 mark).','Keep it concise and accurate — examiners reward precision over length.'],
    Outline:['Give a brief descriptive account of one aspect of the topic.','More than a one-word answer, but not a full explanation with reasons.','1 mark: one clear, accurate point with a small elaboration beyond just naming it.'],
    Explain:['Use "because", "this means that", or "as a result" to develop each reason.','Do not list facts — explain the cause, effect, or reason behind each point.','For 4 marks: two developed reasons. For 2 marks: one developed reason.','No scenario required — answer generically from your knowledge.'],
  };
  const tipRules=rules[verb]||['Use subject-specific vocabulary throughout.','Give exactly as many distinct points as there are marks.','Be accurate and concise.'];
  return`<div class="po1-tip">
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
      <span class="po1-tip-badge">PO1 · Knowledge &amp; Understanding</span>
      <div style="font-size:14px;font-weight:700;color:var(--text);flex:1">${q.marks} mark${q.marks!==1?'s':''} · ${verb} · Direct recall — no scenario required.</div>
    </div>
    <div style="font-size:13px;color:var(--text2);line-height:1.6"><strong>${verb}:</strong> ${cwDef(verb)}</div>
    <div style="display:flex;flex-direction:column;gap:5px">
      ${tipRules.map((r,i)=>`<div class="po-tip-rule"><span class="po-tip-rule-num">${i+1}</span><span>${r}</span></div>`).join('')}
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <button class="btn btn-sm" style="background:var(--po1);color:#fff;border:none" onclick="openPlannerForQ('${pe}',${q.marks},1,'${verb}')">Open Step-by-Step Guide &#8594;</button>
      <button class="btn btn-ghost btn-sm" onclick="switchView('support')">Exam Support</button>
    </div>
  </div>`;
}

function buildPO2Tip(q){
  const verb=q.verb||'';
  const pe=q.plain.replace(/\\/g,'\\\\').replace(/'/g,"\\'");
  const rules={
    Identify:['Points must come from the given scenario — not from general knowledge alone.','Name the feature clearly. One mark per correctly identified feature.','No explanation needed — just identify and name.','Look carefully at the scenario for clues about the specific business, project, or situation.'],
    Explain:['Marks come in PAIRS: 1 mark for stating a point + 1 mark for applying it to the scenario.','You must name the scenario in your answer — generic applications will not earn the second mark.','For 4 marks: 2 pairs of point + application. For 2 marks: 1 pair.','Use "For [scenario], this means..." to signal your application.'],
    Describe:['Give an account of relevant characteristics — not just a list of feature names.','Link each characteristic to the given scenario context.','For 4 marks: 2 characteristics in context. For 2 marks: 1 characteristic in context.','Use scenario-specific language: name the business type, project, or situation.'],
    Compare:['You must address BOTH similarities AND differences to access full marks.','Use comparative language: "Both... however... whereas..."','Link at least one comparison point to the scenario.','Structure: similarity → difference → scenario implication.'],
  };
  const tipRules=rules[verb]||['Link every point specifically to the given scenario.','Marks come in pairs: 1 for the point + 1 for the scenario application.','Use subject-specific vocabulary.'];
  return`<div class="po2-tip">
    <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
      <span class="po2-tip-badge">PO2 · Applied Knowledge</span>
      <div style="font-size:14px;font-weight:700;color:var(--text);flex:1">${q.marks} mark${q.marks!==1?'s':''} · ${verb} · Must be applied to the given scenario.</div>
    </div>
    <div style="font-size:13px;color:var(--text2);line-height:1.6"><strong>${verb}:</strong> ${cwDef(verb)}</div>
    <div style="display:flex;flex-direction:column;gap:5px">
      ${tipRules.map((r,i)=>`<div class="po-tip-rule"><span class="po-tip-rule-num">${i+1}</span><span>${r}</span></div>`).join('')}
    </div>
    <div style="display:flex;gap:8px;flex-wrap:wrap">
      <button class="btn btn-sm" style="background:var(--po2);color:#fff;border:none" onclick="openPlannerForQ('${pe}',${q.marks},2,'${verb}')">Open Step-by-Step Guide &#8594;</button>
      <button class="btn btn-ghost btn-sm" onclick="switchView('support')">Exam Support</button>
    </div>
  </div>`;
}

function buildPO3Tip(q){
  const is6=q.marks===6;
  const bands6=[
    {cls:'l3',marks:'5–6',desc:'<b>Level 3</b> — Two or more developed points, scenario links throughout, balanced judgement, clear conclusion.'},
    {cls:'l2',marks:'3–4',desc:'<b>Level 2</b> — At least one developed point with some scenario link. May lack a clear conclusion.'},
    {cls:'l1',marks:'1–2',desc:'<b>Level 1</b> — Points stated with little development. Mostly knowledge recall only.'},
  ];
  const bands9=[
    {cls:'l3',marks:'7–9',desc:'<b>Level 3</b> — Multiple fully developed points, consistent scenario links, balanced view with counterpoints, clear reasoned conclusion.'},
    {cls:'l2',marks:'4–6',desc:'<b>Level 2</b> — Some development, partially linked to scenario. Some balance shown but conclusion underdeveloped.'},
    {cls:'l1',marks:'1–3',desc:'<b>Level 1</b> — Minimal development. Little scenario reference. No clear conclusion.'},
  ];
  const bands=is6?bands6:bands9;
  const pe=q.plain.replace(/\\/g,'\\\\').replace(/'/g,"\\'");
  return`<div class="po3-tip">
    <div class="po3-tip-top">
      <span class="po3-tip-badge">PO3 · Level of Response</span>
      <div class="po3-tip-title">This is a ${q.marks}-mark extended response — no point scoring, judged holistically across levels.</div>
    </div>
    <div class="po3-tip-body">
      Use the <strong>IDEAL framework</strong>: Identify → Develop → Evidence → Alternative → Link/Conclude.
      ${is6?'Aim for <strong>2 developed points</strong> both linked to the scenario, plus a conclusion.':'Aim for <strong>3 developed points</strong>, show <strong>both sides</strong>, and write a fully reasoned conclusion.'}
      Generic answers without scenario application will not reach Level 3.
    </div>
    <div class="po3-bands">
      ${bands.map(b=>`<div class="po3-band ${b.cls}"><span class="po3-band-marks">${b.marks}</span><span class="po3-band-desc">${b.desc}</span></div>`).join('')}
    </div>
    <div class="po3-tip-actions">
      <button class="btn btn-danger btn-sm" onclick="openPlannerForQ('${pe}',${q.marks},3,'${q.verb||''}')">Plan this answer in Answer Planner &#8594;</button>
      <button class="btn btn-ghost btn-sm" onclick="S.supportSection='ideal';switchView('support')">View IDEAL guide in Exam Support</button>
    </div>
  </div>`;
}

function openPlannerForQ(plain,marks,po,verb){
  S.planner.active=false;
  S.planner.question=plain;
  S.planner.marks=marks;
  S.planner.po=po||null;
  S.planner.verb=verb||null;
  S.planner.practiceMode=false;
  S.planner.checks={};
  switchView('planner');
}

