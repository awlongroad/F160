function getPlannerMarksOpts(po,verb){
  if(po===1){if(verb==='Define')return[1,2];if(verb==='Outline')return[1];if(verb==='State')return[1,2,3,4];if(verb==='Explain')return[2,4];}
  if(po===2){if(verb==='Identify')return[1,2];return[2,4];}
  return[6,9];
}

function getPlannerStages(po,verb,marks){
  const m=marks||0;
  if(po===1){
    if(verb==='Define'){
      const s=[{key:'DEF',label:'Core Definition',hint:'State the precise meaning of the term. Keep it accurate and concise — no examples yet.',sc:'spo1',sb:'spo1',skeleton:'\'[Term]\' is [precise definition].',starters:['\'[Term]\' is a type of [category] that [definition].','\'[Term]\' refers to [definition].','\'[Term]\' can be described as [definition].','[Term] is [definition] and is used to [purpose].']}];
      if(m>=2)s.push({key:'QUAL',label:'Qualifying Detail',hint:'Add a clarifying point, key characteristic, or distinguishing feature that adds precision.',sc:'spo1',sb:'spo1',skeleton:'This means that [qualifying detail / clarification].',starters:['This means that [detail].','A key characteristic is [detail].','This is distinct from [related concept] because [distinction].','For example, [term] [distinguishing feature].']});
      s.push({key:'REV',label:'Review ✓',hint:'Check: Is the definition accurate? Did you avoid vague or circular wording? Have you used the correct technical term?',sc:'sl',sb:'sl',skeleton:null,starters:null});
      return s;
    }
    if(verb==='Outline'){
      return[{key:'ACC',label:'Brief Account',hint:'Give a short descriptive account of one aspect — more than naming it, less than a full explanation.',sc:'spo1',sb:'spo1',skeleton:'[Feature/aspect] is [brief description]. This involves [elaboration].',starters:['[Feature] is [brief description].','One key aspect of [topic] is [description].','[Topic] involves [description].','[Feature] refers to [brief account].']},{key:'REV',label:'Review ✓',hint:'Check: Is your account brief but informative? Did you add a small elaboration beyond just naming the feature?',sc:'sl',sb:'sl',skeleton:null,starters:null}];
    }
    if(verb==='State'){
      const n=m||1;const s=[];
      for(let i=1;i<=n;i++)s.push({key:`P${i}`,label:`Point ${i}`,hint:`State one distinct fact, characteristic, or term. Must be different from every other point — no overlap.`,sc:'spo1',sb:'spo1',skeleton:`[Distinct point / characteristic ${i}].`,starters:['[Subject-specific term]...','One [characteristic/example/phase] is [point].','[Topic] [distinct feature].',`[Point ${i}].`]});
      s.push({key:'REV',label:'Review ✓',hint:`Check: Do you have ${n} distinct, separate points? No two should overlap or mean the same thing. Have you used subject-specific vocabulary throughout?`,sc:'sl',sb:'sl',skeleton:null,starters:null});
      return s;
    }
    if(verb==='Explain'){
      const n=m<=2?1:2;const s=[];
      for(let i=1;i<=n;i++)s.push({key:`R${i}`,label:`Reason ${i} + Development`,hint:'Give a reason or cause and develop it. Do not just state a fact — explain why or what effect it has.',sc:'spo1',sb:'spo1',skeleton:`[Reason/cause] because [development/effect].`,starters:['One reason for [topic] is [reason].','[Cause], because [effect].','This is because [reason], which means that [result].','This leads to [outcome] because [explanation].','This is important because [development].']});
      s.push({key:'REV',label:'Review ✓',hint:'Check: Did you use "because" or "this means that" to develop every reason? Avoid just listing facts.',sc:'sl',sb:'sl',skeleton:null,starters:null});
      return s;
    }
  }
  if(po===2){
    if(verb==='Identify'){
      const n=m||1;const s=[];
      for(let i=1;i<=n;i++)s.push({key:`ID${i}`,label:`Identify ${i}`,hint:'Name one specific feature or characteristic grounded in the given scenario. Do not invent — it must come from the context.',sc:'spo2',sb:'spo2',skeleton:`[Feature/characteristic] — as shown by [scenario reference].`,starters:[`One [feature/characteristic] is [point].`,`[Feature] is evident because the scenario involves [detail].`,`[Topic] [feature], which is relevant to [scenario detail].`]});
      s.push({key:'REV',label:'Review ✓',hint:'Check: Does every point link directly to the given scenario? No purely generic points.',sc:'sl',sb:'sl',skeleton:null,starters:null});
      return s;
    }
    if(verb==='Explain'){
      const pairs=Math.max(1,Math.round(m/2));const s=[];
      for(let i=1;i<=pairs;i++){s.push({key:`PT${i}`,label:`Point ${i}`,hint:'State your point clearly using subject-specific vocabulary. This earns 1 mark.',sc:'spo2',sb:'spo2',skeleton:`One [advantage/feature/reason] of [topic] is [point].`,starters:['One [advantage/feature] of [topic] is [point].','A key reason is [point].','[Topic] allows [point].','One [characteristic/benefit] is [point].']});s.push({key:`AP${i}`,label:`Apply ${i} to the scenario`,hint:'Explain how your point applies specifically to the given scenario. Name it. This earns the second mark.',sc:'spo2',sb:'spo2',skeleton:`For [scenario], this means that [specific application].`,starters:['For [scenario], this means that [application].','In [scenario], this would [specific effect].','This is important for [scenario] because [reason specific to context].','This is especially relevant here because [scenario-specific detail].']});}
      s.push({key:'REV',label:'Review ✓',hint:`Check: Did you apply EVERY point specifically to the scenario? Each pair = 1 point + 1 scenario application. Generic applications do not earn the second mark.`,sc:'sl',sb:'sl',skeleton:null,starters:null});
      return s;
    }
    if(verb==='Describe'){
      const pairs=Math.max(1,Math.round(m/2));const s=[];
      for(let i=1;i<=pairs;i++){s.push({key:`CH${i}`,label:`Characteristic ${i}`,hint:'Describe one relevant feature of the topic using precise, subject-specific language.',sc:'spo2',sb:'spo2',skeleton:`[Topic] [characteristic/feature description].`,starters:['One characteristic of [topic] is [description].','[Topic] typically [feature].','[Topic] involves [description].','A key feature of [topic] is [characteristic].']});s.push({key:`CT${i}`,label:`Context ${i} — scenario link`,hint:'Link that characteristic to the scenario. Explain what it means for the specific situation given.',sc:'spo2',sb:'spo2',skeleton:`In [scenario], this means that [contextual application].`,starters:['In [scenario], this would mean [application].','For [company/team], this is important because [reason].','This is relevant to [scenario] as they need to [need].','For [scenario], this means [impact].']});}
      s.push({key:'REV',label:'Review ✓',hint:'Check: Is each characteristic linked to the scenario? Did you move beyond just naming features to explaining them in context?',sc:'sl',sb:'sl',skeleton:null,starters:null});
      return s;
    }
    if(verb==='Compare'){
      return[{key:'SIM',label:'Similarity',hint:'State at least one thing that [X] and [Y] have in common. Use "Both [X] and [Y]..." structure.',sc:'spo2',sb:'spo2',skeleton:'Both [X] and [Y] [shared characteristic/feature].',starters:['Both [X] and [Y] [shared feature].','[X] and [Y] are similar in that they both [characteristic].','Like [X], [Y] also [shared feature].']},{key:'DIF',label:'Difference',hint:'State at least one key way they differ. Use "however" or "whereas" to signal the contrast.',sc:'spo2',sb:'spo2',skeleton:'However, [X] [feature], whereas [Y] [contrasting feature].',starters:['However, [X] differs from [Y] in that [difference].','Unlike [X], [Y] [contrasting feature].','A key difference is that [X] [feature], but [Y] [contrast].','Whereas [X] [feature], [Y] [contrast].']},{key:'SCN',label:'Scenario link',hint:'Explain which is more relevant or suitable for the specific scenario given, and why.',sc:'spo2',sb:'spo2',skeleton:'For [scenario], [X/Y] is more suitable because [reason specific to context].',starters:['For [scenario], [X] would be more appropriate because [reason].','In this context, [Y] is better suited because [scenario-specific reason].','Given that [scenario detail], [X/Y] is the stronger choice as [reason].']},{key:'REV',label:'Review ✓',hint:'Check: Did you address BOTH similarities AND differences? Did you link at least one point directly to the scenario?',sc:'sl',sb:'sl',skeleton:null,starters:null}];
    }
  }
  return m===6?PLANNER_STAGES_6:PLANNER_STAGES_9;
}

function getPlannerSkeleton(po,verb,marks){
  if(po===3)return marks===9?SKELETON_9:SKELETON_6;
  const stages=getPlannerStages(po,verb,marks);
  return stages.filter(st=>st.skeleton).map(st=>`[${st.label}]\n${st.skeleton}`).join('\n\n');
}

