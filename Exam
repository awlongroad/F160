function getMarksLabel(t){
  if(t.marksOptions)return t.marksOptions.join(' or ');
  if(t.id==='T1')return'1–4';
  if(t.id==='T5')return'1–2';
  if(t.id==='T6'||t.id==='T7')return'2 or 4';
  return t.marksCalc(0)||'?';
}

function renderStep5(w){
  const t=S.tmpl;
  const items=getItems(t);
  const editBanner=S.editingIdx!==null
    ?`<div class="edit-banner"><span class="edit-banner-text">Editing Question ${S.editingIdx+1}</span><button class="edit-banner-cancel" onclick="cancelEdit()">Cancel Edit</button></div>`
    :'';
  w.innerHTML=renderNav(5)+editBanner+`<h1 class="step-heading">Configure Your Question</h1>
  <p class="step-sub">${t.verb} — ${t.label}</p>
  <div class="config-section" id="cfg-section"></div>`;

  const cfg=document.getElementById('cfg-section');

  // Number selector (if needed)
  if(t.needsNumber){
    const max=t.maxN||4;
    const nums=Array.from({length:max},(_,i)=>i+1);
    const marksHint=t.id==='T6'||t.id==='T7'?n=>`${n*2} marks`:n=>`${n} mark${n>1?'s':''}`;
    const f=document.createElement('div');f.className='cfg-field';
    f.innerHTML=`<div class="cfg-label">How many?</div>
    <div class="num-pills">
      ${nums.map(n=>`<button class="num-pill${S.number===n?' sel':''}" onclick="selectNumber(${n})">
        <span>${NUM_WORDS[n]}</span>
        <span class="num-pill-sub">${marksHint(n)}</span>
      </button>`).join('')}
    </div>`;
    cfg.appendChild(f);
  }

  // Item selector
  if(t.needsItem){
    const f=document.createElement('div');f.className='cfg-field';
    f.innerHTML=`<div class="cfg-label">${t.id==='T3'?'Term to define':'Select item'}</div>
    <select class="cfg-select" id="sel-item" onchange="selectItem(this.value)">
      <option value="">— Choose ${t.id==='T3'?'a term':'an item'} —</option>
      ${items.map(it=>`<option value="${it.id}"${S.item?.id===it.id?' selected':''}>${t.id==='T3'?it.term:it.label}</option>`).join('')}
    </select>`;
    cfg.appendChild(f);
  }

  // Content type (if needed)
  if(t.needsCT&&S.item){
    const cts=getContentTypes(t,S.item);
    if(cts.length>0){
      const f=document.createElement('div');f.className='cfg-field';
      f.innerHTML=`<div class="cfg-label">What to ask about</div>
      <select class="cfg-select" id="sel-ct" onchange="selectCT(this.value)">
        <option value="">— Choose content type —</option>
        ${cts.map(c=>`<option value="${c}"${S.ct===c?' selected':''}>${CT[c]?CT[c].p:c}</option>`).join('')}
      </select>`;
      cfg.appendChild(f);
    }
  }

  // Item B (for Compare)
  if(t.needsItemB&&S.item){
    const itemsB=items.filter(it=>it.id!==S.item?.id);
    const f=document.createElement('div');f.className='cfg-field';
    f.innerHTML=`<div class="cfg-label">Compare with (second item)</div>
    <select class="cfg-select" id="sel-itemb" onchange="selectItemB(this.value)">
      <option value="">— Choose second item —</option>
      ${itemsB.map(it=>`<option value="${it.id}"${S.itemB?.id===it.id?' selected':''}>${it.label}</option>`).join('')}
    </select>`;
    cfg.appendChild(f);
  }

  // Scenario (if needed)
  if(t.needsScenario){
    const f=document.createElement('div');f.className='cfg-field';
    f.innerHTML=`<div class="cfg-label">Exam scenario</div>
    <select class="cfg-select" id="sel-scenario" onchange="selectScenario(this.value)">
      <option value="">— Choose a scenario —</option>
      ${SCENARIOS.map(sc=>`<option value="${sc}"${S.scenario===sc?' selected':''}>${sc}</option>`).join('')}
    </select>`;
    cfg.appendChild(f);
  }

  // Marks selector (if needed)
  if(t.needsMarks&&t.marksOptions){
    const f=document.createElement('div');f.className='cfg-field';
    f.innerHTML=`<div class="cfg-label">Mark allocation</div>
    <div class="marks-pills">
      ${t.marksOptions.map(m=>`<button class="marks-pill${S.marks===m?' sel':''}" onclick="selectMarks(${m})">${m} marks</button>`).join('')}
    </div>`;
    cfg.appendChild(f);
  }

  // Preview button
  const f=document.createElement('div');
  f.innerHTML=`<button class="btn btn-primary" onclick="goPreview()" ${isReadyToPreview()?'':'disabled'}>Preview Question →</button>`;
  cfg.appendChild(f);
}

function renderStep6(w){
  if(!isReadyToPreview()){S.step=5;render();return;}
  const q=buildQuestion();
  const editBanner=S.editingIdx!==null
    ?`<div class="edit-banner"><span class="edit-banner-text">Editing Question ${S.editingIdx+1}</span><button class="edit-banner-cancel" onclick="cancelEdit()">Cancel Edit</button></div>`
    :'';
  const addBtn=S.editingIdx!==null
    ?`<button class="btn btn-primary" onclick="addQuestion()">&#10003; Update Question ${S.editingIdx+1}</button>`
    :`<button class="btn btn-success" onclick="addQuestion()">+ Add to Question Paper</button>`;
  const tipBlock=q.po===3?buildPO3Tip(q):q.po===2?buildPO2Tip(q):buildPO1Tip(q);
  w.innerHTML=renderNav(6)+editBanner+`<h1 class="step-heading">Question Preview</h1>
  <p class="step-sub">Review your generated question before adding it to the list.</p>
