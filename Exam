/* Planner question header */
.planner-q-bar{background:var(--surface);border:1.5px solid var(--po3);border-radius:var(--radius);padding:16px 20px;box-shadow:var(--shadow)}
.planner-q-label{font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:0.07em;color:var(--po3);margin-bottom:6px}
.planner-q-text{font-size:16px;font-weight:500;color:var(--text);line-height:1.55}

/* SIDEBAR DEFAULT SCENARIO */
.sidebar-ds{padding:8px 10px 6px;border-bottom:1px solid var(--border)}
.sidebar-ds-label{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:0.06em;color:var(--text3);margin-bottom:5px}
